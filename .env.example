# ============================================================
# APP — Configurações gerais
# ============================================================

# URL base do app em produção (sem barra final)
# Exemplo: https://api.meudominio.com
APP_URL=

# Ambiente: development | production
APP_ENV=development


# ============================================================
# GOOGLE SHEETS — planilha única para os dois produtos
# ============================================================

# ID da planilha
# Encontre no URL: docs.google.com/spreadsheets/d/SPREADSHEET_ID/edit
GOOGLE_SHEETS_SPREADSHEET_ID=

# E-mail da Service Account (formato: nome@projeto-id.iam.gserviceaccount.com)
GOOGLE_SERVICE_ACCOUNT_EMAIL=

# Chave privada da Service Account
# Cole entre aspas duplas no .env.local, mantendo os \n literais:
# GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nABC...\n-----END PRIVATE KEY-----\n"
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=


# ============================================================
# RESEND — envio de e-mails transacionais
# ============================================================

# Chave de API — obtenha em https://resend.com/api-keys
RESEND_API_KEY=

# E-mail remetente (domínio deve estar verificado no Resend)
RESEND_FROM_EMAIL=

# Nome exibido como remetente
RESEND_FROM_NAME=Mentoria


# ============================================================
# HOTMART — webhook único para os dois produtos
# ============================================================

# Token secreto configurado no painel da Hotmart
# Painel > Ferramentas > Webhooks > Token de autenticação
HOTMART_WEBHOOK_TOKEN=


# ============================================================
# HOTMART — Produto: Mentoria Passo 0
# ============================================================

# ID numérico do produto (encontre na URL do produto no painel)
HOTMART_PASSO0_PRODUCT_ID=

# Nome exato como cadastrado na Hotmart (usado como fallback se ID não bater)
HOTMART_PASSO0_PRODUCT_NAME=Mentoria Passo 0


# ============================================================
# HOTMART — Produto: Mentoria 0 a 100
# ============================================================

HOTMART_0100_PRODUCT_ID=
HOTMART_0100_PRODUCT_NAME=Mentoria 0 a 100


# ============================================================
# DRIVE — links de materiais por produto
# ============================================================

# Pasta do Google Drive com materiais da Mentoria Passo 0
PASSO0_DRIVE_ASSETS_URL=

# Pasta do Google Drive com materiais da Mentoria 0 a 100
ZERO100_DRIVE_ASSETS_URL=


# ============================================================
# CORS / SEGURANÇA
# ============================================================

# Origem permitida para o endpoint do formulário
# Em produção: URL exata do seu site (ex: https://meusite.com.br)
# Para liberar tudo (apenas dev): *
ALLOWED_ORIGIN=*
